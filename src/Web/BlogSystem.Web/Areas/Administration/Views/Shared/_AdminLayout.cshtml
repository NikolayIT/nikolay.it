@using BlogSystem.Common
<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewBag.Title - Administration - @GlobalConstants.SystemName</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="shortcut icon" href="/favicon.ico">

    <environment names="Development">
        <link href="~/lib/fontawesome/css/all.css" rel="stylesheet" asp-append-version="true" />
        <link href="~/lib/bootstrap/dist/css/bootstrap.css" rel="stylesheet" asp-append-version="true" />
    </environment>
    <environment names="Staging,Production">
        <link href="~/lib/fontawesome/css/all.min.css" rel="stylesheet" asp-append-version="true" />
        <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" asp-append-version="true" />
    </environment>
    <link href="~/css/admin.min.css" rel="stylesheet" asp-append-version="true" />
</head>

<body class="admin">
    <nav class="navbar navbar-expand-md bg-dark fixed-top" data-bs-theme="dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="Administration" asp-controller="Dashboard" asp-action="Index">
                <i class="fas fa-tools"></i> @GlobalConstants.SystemName &mdash; Administration
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#admin-navbar" aria-controls="admin-navbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div id="admin-navbar" class="collapse navbar-collapse">
                <ul class="navbar-nav d-md-none">
                    <li class="nav-item"><a class="nav-link" asp-area="Administration" asp-controller="Dashboard" asp-action="Index"><i class="fas fa-tachometer-alt fa-fw"></i> Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Administration" asp-controller="BlogPosts" asp-action="Index"><i class="fas fa-file-alt fa-fw"></i> Blog posts</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Administration" asp-controller="Pages" asp-action="Index"><i class="fas fa-copy fa-fw"></i> Pages</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Administration" asp-controller="Videos" asp-action="Index"><i class="fas fa-video fa-fw"></i> Videos</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Administration" asp-controller="Settings" asp-action="Index"><i class="fas fa-sliders-h fa-fw"></i> Settings</a></li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/" target="_blank"><i class="fas fa-external-link-alt"></i> View site</a></li>
                    <li class="nav-item">
                        <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@(this.Url.Content("~/"))">
                            <button type="submit" class="nav-link btn btn-link"><i class="fas fa-sign-out-alt"></i> Logout (@this.User.Identity.Name)</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3 col-lg-2 admin-sidebar d-none d-md-block">
                <ul class="nav flex-column nav-sidebar">
                    <li class="nav-item"><a class="nav-link @this.ActiveClass("Dashboard")" asp-area="Administration" asp-controller="Dashboard" asp-action="Index"><i class="fas fa-tachometer-alt fa-fw"></i> Dashboard</a></li>
                </ul>
                <div class="admin-sidebar-heading">Content</div>
                <ul class="nav flex-column nav-sidebar">
                    <li class="nav-item"><a class="nav-link @this.ActiveClass("BlogPosts")" asp-area="Administration" asp-controller="BlogPosts" asp-action="Index"><i class="fas fa-file-alt fa-fw"></i> Blog posts</a></li>
                    <li class="nav-item"><a class="nav-link @this.ActiveClass("Pages")" asp-area="Administration" asp-controller="Pages" asp-action="Index"><i class="fas fa-copy fa-fw"></i> Pages</a></li>
                    <li class="nav-item"><a class="nav-link @this.ActiveClass("Videos")" asp-area="Administration" asp-controller="Videos" asp-action="Index"><i class="fas fa-video fa-fw"></i> Videos</a></li>
                </ul>
                <div class="admin-sidebar-heading">System</div>
                <ul class="nav flex-column nav-sidebar">
                    <li class="nav-item"><a class="nav-link @this.ActiveClass("Settings")" asp-area="Administration" asp-controller="Settings" asp-action="Index"><i class="fas fa-sliders-h fa-fw"></i> Settings</a></li>
                </ul>
            </div>
            <div class="col-12 col-md-9 offset-md-3 col-lg-10 offset-lg-2 admin-main">
                <partial name="_StatusMessages" />
                @RenderBody()
            </div>
        </div>
    </div>

    <environment names="Development">
        <script src="~/lib/jquery/dist/jquery.js" asp-append-version="true"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js" asp-append-version="true"></script>
    </environment>
    <environment names="Staging,Production">
        <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    </environment>

    @await this.RenderSectionAsync("Scripts", required: false)
</body>
</html>

@functions {
    private string ActiveClass(string controllerName)
    {
        var currentController = (string)this.ViewContext.RouteData.Values["controller"];
        return string.Equals(currentController, controllerName, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
    }
}
