@model BlogSystem.Web.ViewModels.Administration.PaginatedListViewModel<BlogSystem.Web.ViewModels.Administration.Videos.VideoRowViewModel>

@{
    ViewData["Title"] = "Videos";
}

<div class="admin-page-header clearfix">
    <h1><i class="fas fa-video"></i> Videos <small>(@Model.TotalCount)</small></h1>
    <div class="admin-page-actions">
        <a href="/Videos" target="_blank" class="btn btn-default"><i class="fas fa-external-link-alt"></i> View on site</a>
        <form asp-action="FetchLatest" method="post" style="display: inline;">
            <button type="submit" class="btn btn-primary"><i class="fab fa-youtube"></i> Fetch latest from YouTube</button>
        </form>
    </div>
</div>

@if (Model.Items.Any())
{
    <div class="panel panel-default">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th></th>
                    <th>Title</th>
                    <th>Video</th>
                    <th>Status</th>
                    <th>Added</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var video in Model.Items)
                {
                    <tr class="@(video.IsDeleted ? "danger" : string.Empty)">
                        <td><img src="https://i.ytimg.com/vi/@(video.VideoId)/default.jpg" alt="Thumbnail" class="admin-video-thumbnail" /></td>
                        <td>@video.Title</td>
                        <td><a href="https://www.youtube.com/watch?v=@video.VideoId" target="_blank">@video.VideoId <i class="fas fa-external-link-alt"></i></a></td>
                        <td>
                            @if (video.IsDeleted)
                            {
                                <span class="label label-danger">Hidden</span>
                            }
                            else
                            {
                                <span class="label label-success">Visible</span>
                            }
                        </td>
                        <td>@video.CreatedOn.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="admin-row-actions">
                            @if (!video.IsDeleted)
                            {
                                <form asp-action="Delete" asp-route-id="@video.Id" asp-route-page="@Model.PageNumber" method="post">
                                    <button type="submit" class="btn btn-danger btn-xs" onclick="return confirm('Hide this video from the site? It can be restored later.');"><i class="fas fa-trash-alt"></i> Delete</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Restore" asp-route-id="@video.Id" asp-route-page="@Model.PageNumber" method="post">
                                    <button type="submit" class="btn btn-success btn-xs"><i class="fas fa-undo"></i> Restore</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pager" model="@((BlogSystem.Web.ViewModels.Administration.PaginationViewModel)Model)" />
}
else
{
    <div class="panel panel-default">
        <div class="panel-body text-muted">There are no videos yet. Use the "Fetch latest from YouTube" button to import them.</div>
    </div>
}
