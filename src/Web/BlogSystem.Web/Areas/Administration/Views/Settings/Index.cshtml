@model System.Collections.Generic.IEnumerable<BlogSystem.Web.ViewModels.Administration.Settings.SettingRowViewModel>

@{
    ViewData["Title"] = "Settings";
}

<div class="admin-page-header clearfix">
    <h1><i class="fas fa-sliders-h"></i> Settings <small class="text-body-secondary">(@Model.Count())</small></h1>
    <div class="admin-page-actions">
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> New setting</a>
    </div>
</div>

@if (Model.Any())
{
    <div class="card">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Value</th>
                    <th>Status</th>
                    <th>Modified</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var setting in Model)
                {
                    <tr class="@(setting.IsDeleted ? "table-danger" : string.Empty)">
                        <td><a asp-action="Edit" asp-route-id="@setting.Id"><code>@setting.Name</code></a></td>
                        <td>@(setting.Value?.Length > 100 ? setting.Value.Substring(0, 100) + "…" : setting.Value)</td>
                        <td>
                            @if (setting.IsDeleted)
                            {
                                <span class="badge text-bg-danger">Deleted</span>
                            }
                            else
                            {
                                <span class="badge text-bg-success">Active</span>
                            }
                        </td>
                        <td>@((setting.ModifiedOn ?? setting.CreatedOn).ToString("yyyy-MM-dd HH:mm"))</td>
                        <td class="admin-row-actions">
                            @if (!setting.IsDeleted)
                            {
                                <a asp-action="Edit" asp-route-id="@setting.Id" class="btn btn-outline-secondary btn-sm"><i class="fas fa-pencil-alt"></i> Edit</a>
                                <form asp-action="Delete" asp-route-id="@setting.Id" method="post">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this setting? It can be restored later.');"><i class="fas fa-trash-alt"></i> Delete</button>
                                </form>
                            }
                            else
                            {
                                <a asp-action="Edit" asp-route-id="@setting.Id" class="btn btn-outline-secondary btn-sm"><i class="fas fa-pencil-alt"></i> Edit</a>
                                <form asp-action="Restore" asp-route-id="@setting.Id" method="post">
                                    <button type="submit" class="btn btn-success btn-sm"><i class="fas fa-undo"></i> Restore</button>
                                </form>
                                <form asp-action="HardDelete" asp-route-id="@setting.Id" method="post">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Permanently delete this setting? This CANNOT be undone.');"><i class="fas fa-times"></i> Delete forever</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-body-secondary">There are no settings yet. <a asp-action="Create">Create the first one</a>.</div>
    </div>
}
