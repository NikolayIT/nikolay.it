@using BlogSystem.Services
@model BlogSystem.Web.ViewModels.Administration.PaginatedListViewModel<BlogSystem.Web.ViewModels.Administration.BlogPosts.BlogPostRowViewModel>
@inject IBlogUrlGenerator UrlGenerator

@{
    ViewData["Title"] = "Blog Posts";
}

<div class="admin-page-header clearfix">
    <h1><i class="fas fa-file-alt"></i> Blog posts <small class="text-body-secondary">(@Model.TotalCount)</small></h1>
    <div class="admin-page-actions">
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> New blog post</a>
    </div>
</div>

<form method="get" class="d-flex align-items-center mb-3">
    <div class="input-group" style="max-width: 320px;">
        <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by title..." />
        <button type="submit" class="btn btn-outline-secondary"><i class="fas fa-search"></i></button>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
    {
        <a asp-action="Index" class="btn btn-link">Clear</a>
    }
</form>

@if (Model.Items.Any())
{
    <div class="card mb-3">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Modified</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in Model.Items)
                {
                    <tr class="@(post.IsDeleted ? "table-danger" : string.Empty)">
                        <td>
                            <a asp-action="Edit" asp-route-id="@post.Id">@post.Title</a>
                            @if (post.IsPinned)
                            {
                                <i class="fas fa-thumbtack text-body-secondary" title="Pinned"></i>
                            }
                        </td>
                        <td><span class="badge text-bg-secondary">@post.Type</span></td>
                        <td>
                            @if (post.IsDeleted)
                            {
                                <span class="badge text-bg-danger">Deleted</span>
                            }
                            else
                            {
                                <span class="badge text-bg-success">Published</span>
                            }
                        </td>
                        <td>@post.CreatedOn.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(post.ModifiedOn?.ToString("yyyy-MM-dd HH:mm"))</td>
                        <td class="admin-row-actions">
                            @if (!post.IsDeleted)
                            {
                                <a href="@UrlGenerator.GenerateUrl(post.Id, post.Title, post.CreatedOn)" target="_blank" class="btn btn-outline-secondary btn-sm" title="View on site"><i class="fas fa-external-link-alt"></i></a>
                                <a asp-action="Edit" asp-route-id="@post.Id" class="btn btn-outline-secondary btn-sm"><i class="fas fa-pencil-alt"></i> Edit</a>
                                <form asp-action="Delete" asp-route-id="@post.Id" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@Model.PageNumber" method="post">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this blog post? It can be restored later.');"><i class="fas fa-trash-alt"></i> Delete</button>
                                </form>
                            }
                            else
                            {
                                <a asp-action="Edit" asp-route-id="@post.Id" class="btn btn-outline-secondary btn-sm"><i class="fas fa-pencil-alt"></i> Edit</a>
                                <form asp-action="Restore" asp-route-id="@post.Id" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@Model.PageNumber" method="post">
                                    <button type="submit" class="btn btn-success btn-sm"><i class="fas fa-undo"></i> Restore</button>
                                </form>
                                <form asp-action="HardDelete" asp-route-id="@post.Id" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@Model.PageNumber" method="post">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Permanently delete this blog post? This CANNOT be undone.');"><i class="fas fa-times"></i> Delete forever</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pager" model="@((BlogSystem.Web.ViewModels.Administration.PaginationViewModel)Model)" />
}
else
{
    <div class="card">
        <div class="card-body text-body-secondary">
            @if (string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <text>There are no blog posts yet. <a asp-action="Create">Create the first one</a>.</text>
            }
            else
            {
                <text>No blog posts match "<strong>@Model.SearchTerm</strong>". <a asp-action="Index">Show all</a>.</text>
            }
        </div>
    </div>
}
