@using BlogSystem.Services
@model BlogSystem.Web.ViewModels.Administration.BlogPosts.BlogPostEditViewModel
@inject IBlogUrlGenerator UrlGenerator

@{
    ViewData["Title"] = "Edit Blog Post";
}

<div class="admin-page-header clearfix">
    <h1><i class="fas fa-file-alt"></i> Edit blog post</h1>
    <div class="admin-page-actions">
        @if (!Model.IsDeleted && !string.IsNullOrWhiteSpace(Model.Title))
        {
            <a href="@UrlGenerator.GenerateUrl(Model.Id, Model.Title, Model.CreatedOn)" target="_blank" class="btn btn-outline-secondary"><i class="fas fa-external-link-alt"></i> View on site</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Back to list</a>
    </div>
</div>

@if (Model.IsDeleted)
{
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i> This blog post is deleted and is not visible on the site. You can restore it from the blog posts list.
    </div>
}

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <partial name="_BlogPostFormFields" model="Model" />
    <div class="admin-form-footer clearfix">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save changes</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <div class="float-end text-end admin-meta-list">
            <div>Created on @Model.CreatedOn.ToString("yyyy-MM-dd HH:mm")</div>
            @if (Model.ModifiedOn != null)
            {
                <div>Last modified on @Model.ModifiedOn.Value.ToString("yyyy-MM-dd HH:mm")</div>
            }
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
