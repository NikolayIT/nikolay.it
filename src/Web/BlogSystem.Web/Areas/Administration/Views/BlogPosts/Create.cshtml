@model BlogSystem.Web.ViewModels.Administration.BlogPosts.BlogPostInputModel

@{
    ViewData["Title"] = "New Blog Post";
}

<div class="admin-page-header clearfix">
    <h1><i class="fas fa-file-alt"></i> New blog post</h1>
    <div class="admin-page-actions">
        <a asp-action="Index" class="btn btn-default"><i class="fas fa-arrow-left"></i> Back to list</a>
    </div>
</div>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <partial name="_BlogPostFormFields" model="Model" />
    <div class="admin-form-footer">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create post</button>
        <a asp-action="Index" class="btn btn-default">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
