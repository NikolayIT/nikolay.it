@model BlogSystem.Web.ViewModels.Administration.Pages.PageEditViewModel

@{
    ViewData["Title"] = "Edit Page";
}

<div class="admin-page-header clearfix">
    <h1><i class="fas fa-copy"></i> Edit page</h1>
    <div class="admin-page-actions">
        @if (!Model.IsDeleted)
        {
            <a href="/Pages/@Model.Permalink" target="_blank" class="btn btn-default"><i class="fas fa-external-link-alt"></i> View on site</a>
        }
        <a asp-action="Index" class="btn btn-default"><i class="fas fa-arrow-left"></i> Back to list</a>
    </div>
</div>

@if (Model.IsDeleted)
{
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i> This page is deleted and is not visible on the site. You can restore it from the pages list.
    </div>
}

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <partial name="_PageFormFields" model="Model" />
    <div class="admin-form-footer clearfix">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save changes</button>
        <a asp-action="Index" class="btn btn-default">Cancel</a>
        <div class="pull-right text-right admin-meta-list">
            <div>Created on @Model.CreatedOn.ToString("yyyy-MM-dd HH:mm")</div>
            @if (Model.ModifiedOn != null)
            {
                <div>Last modified on @Model.ModifiedOn.Value.ToString("yyyy-MM-dd HH:mm")</div>
            }
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
